APP_ENV=local
APP_NAME=Healthclaw
API_KEY=dev-healthclaw-key
DATABASE_URL=postgresql+asyncpg://healthclaw:healthclaw@localhost:5432/healthclaw
AUTO_CREATE_DB=false
REDIS_URL=redis://localhost:6379/0
DEFAULT_TIMEZONE=Asia/Colombo
DEFAULT_QUIET_START=22:00
DEFAULT_QUIET_END=07:00
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=moonshotai/kimi-k2.6
OPENROUTER_CHAT_FALLBACK_MODELS=minimax/minimax-m2.7,openai/gpt-5.4-mini
OPENROUTER_CHAT_MAX_TOKENS=700
OPENROUTER_CHAT_TEMPERATURE=0.75
RECENT_MESSAGE_CONTEXT_LIMIT=30
RECENT_MESSAGE_CONTEXT_MAX_CHARS=12000
OPENROUTER_TRANSCRIBE_MODEL=mistralai/voxtral-small-24b-2507
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Healthclaw
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=healthclaw
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_RAW_CONTENT=false
