APP_ENV=local
APP_NAME=Healthclaw
API_KEY=dev-healthclaw-key
DATABASE_URL=postgresql+asyncpg://healthclaw:healthclaw@localhost:5432/healthclaw
AUTO_CREATE_DB=false
REDIS_URL=redis://localhost:6379/0
DEFAULT_TIMEZONE=Asia/Colombo
DEFAULT_QUIET_START=22:00
DEFAULT_QUIET_END=07:00
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=moonshotai/kimi-k2.6
OPENROUTER_CHAT_FALLBACK_MODELS=minimax/minimax-m2.7,openai/gpt-5.4-mini
OPENROUTER_CHAT_MAX_TOKENS=700
OPENROUTER_CHAT_TEMPERATURE=0.75
RECENT_MESSAGE_CONTEXT_LIMIT=30
RECENT_MESSAGE_CONTEXT_MAX_CHARS=12000
OPENROUTER_TRANSCRIBE_MODEL=mistralai/voxtral-small-24b-2507
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Healthclaw
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=healthclaw
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_RAW_CONTENT=false

# WS6: Memory / context optimization
MAX_CONTEXT_TOKENS=16000
CONTEXT_TOKEN_RESERVE_SYSTEM=2500
CONTEXT_TOKEN_RESERVE_OUTPUT=1500
RERANKER_PROVIDER=none
RERANKER_MODEL=rerank-v3.5
COHERE_API_KEY=
RERANK_TOP_K_MULTIPLIER=3
RERANKER_TIMEOUT_MS=400

# WS6: Motives & self-model
MOTIVES_ENABLED=false
MOTIVE_DECAY_HALF_LIFE_DAYS=21
MOTIVE_SEED_WEIGHT=0.3

# WS6: Inner synthesizer / anticipation
INNER_SYNTHESIZER_ENABLED=false
INNER_SYNTH_MODEL=moonshotai/kimi-k2.6
INNER_SYNTH_MAX_TOKENS=400
INNER_SYNTH_TEMPERATURE=0.6
ANTICIPATION_ENABLED=false
HYDRATION_POLLER_ENABLED=false

# WS6: Health skills (LLM-activated, no regex)
HEALTH_SKILLS_ENABLED=false
HEALTH_SKILL_MAX_ACTIVE=2
SKILL_ACTIVATOR_MODEL=google/gemini-2.5-flash-lite
SKILL_ACTIVATOR_MAX_TOKENS=120
HEALTH_SKILL_SLEEP_ENABLED=false
HEALTH_SKILL_NUTRITION_ENABLED=false
HEALTH_SKILL_MOVEMENT_ENABLED=false
HEALTH_SKILL_MENTAL_HEALTH_ENABLED=false
HEALTH_SKILL_MEDICATION_ADHERENCE_ENABLED=false

# WS6: Crisis (LLM self-tagged, no regex)
CRISIS_HOTLINE_DEFAULT=988
CRISIS_HOTLINE_LOCALE_MAP={"GB":"116123","AU":"131114","LK":"1926","SG":"1767"}

# WS6: Web search (Tavily)
TAVILY_API_KEY=
TAVILY_SEARCH_TIMEOUT_MS=4000
WEB_SEARCH_ENABLED=false
WEB_SEARCH_CACHE_TTL_SECONDS=900
WEB_SEARCH_HEALTH_DOMAINS_ONLY=true
